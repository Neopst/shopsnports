{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "SecretsManagerReadECSUpdate",
      "Effect": "Allow",
      "Action": [
        "secretsmanager:GetSecretValue",
        "secretsmanager:DescribeSecret"
      ],
      "Resource": [
        "arn:aws:secretsmanager:{{REGION}}:{{ACCOUNT_ID}}:secret:shopsnports/production/*"
      ]
    },
    {
      "Sid": "ECSDescribeAndUpdate",
      "Effect": "Allow",
      "Action": [
        "ecs:DescribeTaskDefinition",
        "ecs:RegisterTaskDefinition",
        "ecs:UpdateService",
        "iam:PassRole"
      ],
      "Resource": "*"
    },
    {
      "Sid": "Logs",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogStream",
        "logs:PutLogEvents"
      ],
      "Resource": "*"
    }
  ]
}
