{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowCreateSpecificShopRole",
      "Effect": "Allow",
      "Action": [
        "iam:CreateRole",
        "iam:GetRole",
        "iam:DeleteRole",
        "iam:TagRole",
        "iam:PassRole",
        "iam:PutRolePolicy",
        "iam:DeleteRolePolicy"
      ],
      "Resource": "arn:aws:iam::119495459751:role/shopsnports-*"
    },
    {
      "Sid": "AllowListAndRead",
      "Effect": "Allow",
      "Action": [
        "iam:ListRoles",
        "iam:GetRolePolicy",
        "iam:ListRolePolicies"
      ],
      "Resource": "*"
    }
  ]
}
