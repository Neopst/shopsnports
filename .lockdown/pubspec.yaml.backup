name: shopsnports
description: ShopsNports mobile app
publish_to: "none"
version: 1.0.0+1

environment:
  sdk: ">=3.3.0 <4.0.0"

dependencies:
  carousel_slider: ^5.1.1
  cloud_firestore: ^6.0.2
  file_picker: ^10.3.3
  firebase_auth: ^6.1.0
  firebase_core: ^4.1.1
  flutter:
    sdk: flutter
  flutter_lints: ^6.0.0
  flutter_riverpod: ^2.0.0
  geocoding: ^4.0.0
  geolocator: ^14.0.2
  http: ^1.5.0
  liquid_pull_to_refresh: ^3.0.1
  provider: ^6.1.5+1
  shared_preferences: ^2.5.3
  shimmer: ^3.0.0

dev_dependencies:
  flutter_test:
    sdk: flutter

flutter:
  uses-material-design: true
  assets:
    - assets/designs/