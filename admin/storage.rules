rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // =========================================================================
    // Shipping Request Documents
    // =========================================================================
    match /shippingRequests/{requestId}/documents/{document} {
      // Allow anyone to read shipping documents (for tracking/support)
      allow read: if true;
      
      // Allow ANYONE to upload documents for shipping requests (guest users included)
      // Note: Mobile app should use Firebase Anonymous Auth for better tracking
      allow write: if request.resource.size < 10 * 1024 * 1024 && // 10MB file size limit
                      request.resource.contentType.matches('image/.*|application/pdf'); // Only images and PDFs
      
      // Allow authenticated users to delete documents
      allow delete: if request.auth != null;
    }
    
    // =========================================================================
    // User Profile Pictures
    // =========================================================================
    match /users/{userId}/profile/{filename} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && 
                      request.auth.uid == userId &&
                      request.resource.size < 5 * 1024 * 1024 && // 5MB limit
                      request.resource.contentType.matches('image/.*');
    }
    
    // =========================================================================
    // Vendor/Product Images
    // =========================================================================
    match /vendors/{vendorId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
                      request.resource.size < 10 * 1024 * 1024 &&
                      request.resource.contentType.matches('image/.*');
    }
    
    // =========================================================================
    // General Upload Folder (Temporary uploads)
    // =========================================================================
    match /uploads/{userId}/{filename} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && 
                      request.auth.uid == userId &&
                      request.resource.size < 20 * 1024 * 1024; // 20MB limit
      allow delete: if request.auth != null && request.auth.uid == userId;
    }
    
    // =========================================================================
    // Admin Uploads (News, Content, etc.)
    // =========================================================================
    match /admin/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null; // Admin check happens in Firestore
    }
    
    // =========================================================================
    // Public Assets (Read-only for authenticated users)
    // =========================================================================
    match /public/{allPaths=**} {
      allow read: if true; // Public read access
      allow write: if request.auth != null; // Only authenticated users can upload
    }

    // =========================================================================
    // Banner Images (Public read for carousel/home screen)
    // =========================================================================
    match /banners/{filename} {
      allow read: if true; // Public read - anyone can view banners
      allow write: if request.auth != null; // Authenticated users (admin dashboard users) can upload
      allow delete: if request.auth != null; // Authenticated users can delete
    }
